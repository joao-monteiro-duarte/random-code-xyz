# EditorConfig helps maintain consistent coding styles for multiple developers
# See https://editorconfig.org/

root = true

# Default configuration for all files
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Python-specific configuration
[*.py]
indent_size = 4
max_line_length = 100

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Docker files
[Dockerfile*]
indent_size = 4

# HTML and templates
[*.{html,htm,tmpl}]
indent_size = 2

# CSS, SCSS, LESS
[*.{css,scss,less}]
indent_size = 2

# JavaScript and TypeScript
[*.{js,ts,jsx,tsx}]
indent_size = 2