# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here

# Exchange Keys (for trading)
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_API_SECRET=your_exchange_api_secret_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EXPIRE=86400  # 24 hours in seconds

# Application Settings
VPH_THRESHOLD=200
CYCLE_INTERVAL=1800  # 30 minutes in seconds
FETCH_INTERVAL=300   # 5 minutes in seconds
MAX_VIDEOS=100
MAX_VIDEOS_PER_FETCH=10

# Test Settings
TEST_MODE=true
REDIS_TEST_MODE=true
THROTTLE_MINUTES=60  # 1 hour in minutes