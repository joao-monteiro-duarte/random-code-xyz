# API Keys
OPENROUTER_API_KEY=your_openrouter_key_here  # For Mixtral-8x7b-instruct access
ANTHROPIC_API_KEY=your_anthropic_key_here    # For Claude 3 Sonnet access
COINGECKO_API_KEY=your_coingecko_key_here    # For market data

# Trading Configuration (for simulated or live trading)
EXCHANGE_API_KEY=your_exchange_key_here
EXCHANGE_API_SECRET=your_exchange_secret_here
TEST_MODE=true  # Set to false for live trading (use with caution!)

# System Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TEST_MODE=true  # Use FakeRedis for testing

# Cycle Configuration
CYCLE_INTERVAL=30  # Minutes between comprehensive cycles
QUICK_DECISION_INTERVAL=5  # Minutes between quick decision cycles
VPH_THRESHOLD=500.0  # Minimum views-per-hour for video processing

# Transcript Settings
WHISPER_MODEL=small  # Options: tiny, base, small, medium, large
YOUTUBE_API_KEYS=["your_youtube_api_key1","your_youtube_api_key2"]  # For fetching video metadata

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=app.log

# Advanced Settings
SENTIMENT_SIGNIFICANCE_THRESHOLD=1.0  # Minimum change to trigger quick decision
THROTTLE_PERIOD=60  # Minutes to wait before trading the same coin again
FRESHNESS_BOOST=1.2  # 20% boost for new content
NEW_COIN_BOOST=1.1  # 10% boost for newly discovered coins